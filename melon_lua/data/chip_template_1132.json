    {
      "key": "lua_chip_source",
      "boolValue": false,
      "stringValue": "-- Lua Chip: Getting Started (runnable demo of all API modules)\n-- Code outside functions runs ONCE. OnTick() is REQUIRED.\n-- Local variables persist between ticks in the Lua VM.\n-- ============ Local state (not saved to disk) ============\nlocal tick = 0\nlocal hue = 0\n\n-- ============ Configuration ============\nlocal COLOR_SPEED = 0.5   -- Speed of color shifting (higher value = faster)\n\n-- ============ Lifecycle ============\n\nfunction OnInit()\n    tick = 0\n    hue = 0\n    print(\"Color cycler chip initialized.\")\nend\n\nfunction OnDestroy()\n    print(\"Color cycler chip destroyed.\")\nend\n\n-- ============ Main Tick ============\n\nfunction OnTick()\n    tick = tick + 1\n    local dt = env.deltaTime()\n\n    -- 1. Get the target entity from input connection\n    local targetId = inputs.entity.target\n\n    if targetId and targetId ~= 0 then\n        local ent = Entity(targetId)\n        \n        if ent:isValid() == 1 then\n            -- 2. Cycle hue value smoothly over time (keep it between 0 and 1)\n            hue = hue + dt * COLOR_SPEED\n            if hue > 1 then \n                hue = hue - 1 \n            end\n\n            -- 3. Convert Hue to RGB channels\n            local r = math.abs(hue * 6 - 3) - 1\n            local g = 2 - math.abs(hue * 6 - 2)\n            local b = 2 - math.abs(hue * 6 - 4)\n\n            -- Clamp RGB values strictly between 0.0 and 1.0\n            r = math.max(0, math.min(1, r))\n            g = math.max(0, math.min(1, g))\n            b = math.max(0, math.min(1, b))\n\n            -- 4. Apply the calculated color (Red, Green, Blue, Alpha)\n            ent:setColor(r, g, b, 1)\n            \n            outputs.string.status = \"Cycling color. Current Hue: \" .. string.format(\"%.2f\", hue)\n        else\n            outputs.string.status = \"Error: Connected target is invalid\"\n        end\n    else\n        outputs.string.status = \"Waiting: Connect an entity to 'target' input\"\n    end\n\n    -- 5. Standard Output\n    outputs.num.tick = tick\nend\n",
